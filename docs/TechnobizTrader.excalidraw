    { "id": "pos_txt", "type": "text", "x": 746, "y": 510, "width": 638, "height": 190, "angle": 0, "strokeColor": "#94a3b8", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "groupIds": [], "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false, "text": "POSITION SIZING FORMULA  (2% Risk Rule)\n\nrisk_pips  =  |entry - stop_loss|  /  0.0001\nmax_risk$  =  account_balance  x  0.02\nlots         =  max_risk$  /  (risk_pips  x  $10 per pip)\n\nExample:  $10,000 balance,  20-pip SL\n  max_risk = $200     lots = $200 / (20 x $10) = 1.00 lot", "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "lineHeight": 1.6, "containerId": null },

