//@version=6
strategy("TechnobizTrader – Gold ICT Strategy v6", overlay=true,
         default_qty_type=strategy.percent_of_equity, default_qty_value=2,
         initial_capital=10000, currency=currency.USD,
         pyramiding=0, calc_on_order_fills=false,
         max_bars_back=500)

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════════════════════
var g_trend  = "Trend Settings"
swingLen     = input.int(10,    "Swing Lookback Bars",        minval=5,    maxval=50,  group=g_trend)
htf          = input.timeframe("240", "Higher Timeframe Bias (4H default)", group=g_trend)

var g_ict    = "ICT Settings"
obLookback   = input.int(20,    "Order Block Lookback",       minval=5,    maxval=100, group=g_ict)
sweepBuf     = input.float(0.05,"Liquidity Sweep Buffer %",  minval=0.01, maxval=0.5, group=g_ict)

var g_risk   = "Risk Management"
rrMin        = input.float(2.0, "Min Risk/Reward Ratio",     minval=1.5,  maxval=5.0, group=g_risk)
tp1Pct       = input.float(50.0,"TP1 Close %",               minval=10,   maxval=80,  group=g_risk)
tp2Pct       = input.float(30.0,"TP2 Close %",               minval=10,   maxval=60,  group=g_risk)
trailPts     = input.int(200,   "TP3 Trail Points (price)",  minval=50,   maxval=1000,group=g_risk)

var g_sess   = "Kill Zone Sessions (GMT)"
useSession   = input.bool(true, "Enable Kill Zone Filter",   group=g_sess)
londonSess   = input.session("0800-1200", "London Kill Zone",group=g_sess)
nySess       = input.session("1300-1700", "New York Kill Zone",group=g_sess)

var g_vis    = "Visuals"
showOB       = input.bool(true, "Show Order Blocks",         group=g_vis)
showFVG      = input.bool(true, "Show Fair Value Gaps (FVG)",group=g_vis)
showSweeps   = input.bool(true, "Show Liquidity Sweeps",     group=g_vis)
showTable    = input.bool(true, "Show Info Table",           group=g_vis)

// ══════════════════════════════════════════════════════════════════════════════
// HIGHER TIMEFRAME BIAS
// ══════════════════════════════════════════════════════════════════════════════
htfClose   = request.security(syminfo.tickerid, htf, close,       lookahead=barmerge.lookahead_off)
htfEma50   = request.security(syminfo.tickerid, htf, ta.ema(close, 50),  lookahead=barmerge.lookahead_off)
htfEma200  = request.security(syminfo.tickerid, htf, ta.ema(close, 200), lookahead=barmerge.lookahead_off)

htfBull    = htfClose > htfEma50  and htfEma50  > htfEma200
htfBear    = htfClose < htfEma50  and htfEma50  < htfEma200

// ══════════════════════════════════════════════════════════════════════════════
// SWING STRUCTURE (Higher Highs / Higher Lows)
// ══════════════════════════════════════════════════════════════════════════════
swingHigh  = ta.pivothigh(high, swingLen, swingLen)
swingLow   = ta.pivotlow (low,  swingLen, swingLen)

var float lastSH  = na
var float prevSH  = na
var float lastSL  = na
var float prevSL  = na

if not na(swingHigh)
    prevSH := lastSH
    lastSH := swingHigh

if not na(swingLow)
    prevSL := lastSL
    lastSL := swingLow

bullStruct = not na(lastSH) and not na(prevSH) and not na(lastSL) and not na(prevSL)
           and lastSH > prevSH and lastSL > prevSL  // HH + HL

bearStruct = not na(lastSH) and not na(prevSH) and not na(lastSL) and not na(prevSL)
           and lastSH < prevSH and lastSL < prevSL  // LH + LL

// ══════════════════════════════════════════════════════════════════════════════
// LIQUIDITY SWEEP DETECTION
// ══════════════════════════════════════════════════════════════════════════════
recentHigh  = ta.highest(high, obLookback)
recentLow   = ta.lowest (low,  obLookback)
bufH        = recentHigh[1] * (sweepBuf / 100)
bufL        = recentLow[1]  * (sweepBuf / 100)

// Swept high: wick above prior range high but candle closed back below it
sweepHigh   = high > recentHigh[1] + bufH and close < recentHigh[1]
// Swept low:  wick below prior range low  but candle closed back above it
sweepLow    = low  < recentLow[1]  - bufL and close > recentLow[1]

// ══════════════════════════════════════════════════════════════════════════════
// BREAK OF STRUCTURE (BoS)
// ══════════════════════════════════════════════════════════════════════════════
bosUp   = not na(lastSH) and close > lastSH  // Price breaks above last swing high → bullish BoS
bosDown = not na(lastSL) and close < lastSL  // Price breaks below last swing low  → bearish BoS

// ══════════════════════════════════════════════════════════════════════════════
// ORDER BLOCK DETECTION
// ══════════════════════════════════════════════════════════════════════════════
var float bullOBH = na
var float bullOBL = na
var float bearOBH = na
var float bearOBL = na
var int   bullOBBar = na
var int   bearOBBar = na

if bosUp
    // Bullish OB = last DOWN candle before the impulse move up
    for i = 1 to obLookback
        if close[i] < open[i]
            bullOBH   := high[i]
            bullOBL   := low[i]
            bullOBBar := bar_index - i
            break

if bosDown
    // Bearish OB = last UP candle before the impulse move down
    for i = 1 to obLookback
        if close[i] > open[i]
            bearOBH   := high[i]
            bearOBL   := low[i]
            bearOBBar := bar_index - i
            break

// ══════════════════════════════════════════════════════════════════════════════
// FAIR VALUE GAP / IMBALANCE (FVG)
// ══════════════════════════════════════════════════════════════════════════════
// Bullish FVG: candle[0] low > candle[2] high (gap between them, middle candle is bullish)
bullFVG   = low > high[2] and close[1] > open[1]
// Bearish FVG: candle[0] high < candle[2] low
bearFVG   = high < low[2]  and close[1] < open[1]

// ══════════════════════════════════════════════════════════════════════════════
// KILL ZONE SESSION FILTER
// ══════════════════════════════════════════════════════════════════════════════
inLondon   = useSession ? not na(time(timeframe.period, londonSess, "GMT+0")) : true
inNY       = useSession ? not na(time(timeframe.period, nySess,     "GMT+0")) : true
inKillZone = inLondon or inNY

// ══════════════════════════════════════════════════════════════════════════════
// ENTRY CONDITIONS (All 4 ICT Elements Must Be Present)
// ══════════════════════════════════════════════════════════════════════════════
// LONG:  HTF bullish + bull structure + recent sweep of lows + BoS up
//        + price pulled back into bullish order block + inside kill zone
longSetup  = htfBull
           and bullStruct
           and sweepLow[1]
           and bosUp
           and not na(bullOBH)
           and close <= bullOBH
           and close >= bullOBL
           and inKillZone

// SHORT: HTF bearish + bear structure + recent sweep of highs + BoS down
//        + price pulled back into bearish order block + inside kill zone
shortSetup = htfBear
           and bearStruct
           and sweepHigh[1]
           and bosDown
           and not na(bearOBH)
           and close >= bearOBL
           and close <= bearOBH
           and inKillZone

// ══════════════════════════════════════════════════════════════════════════════
// STOP LOSS & TAKE PROFIT LEVELS
// ══════════════════════════════════════════════════════════════════════════════
pip          = syminfo.mintick * 10   // 1 pip for XAUUSD

// Long levels
longSL       = bullOBL - pip * 2
longRange    = not na(lastSH) ? (lastSH - close) : (close - longSL) * rrMin
longTP1      = close + longRange
longTP2      = close + longRange * 1.5
// TP3 uses trailing stop

// Short levels
shortSL      = bearOBH + pip * 2
shortRange   = not na(lastSL) ? (close - lastSL) : (shortSL - close) * rrMin
shortTP1     = close - shortRange
shortTP2     = close - shortRange * 1.5

// Risk/Reward validation
longRR       = (longTP1  - close) / math.max(close - longSL,  pip)
shortRR      = (close - shortTP1) / math.max(shortSL - close, pip)

// ══════════════════════════════════════════════════════════════════════════════
// STRATEGY EXECUTION (Max 3 concurrent trades enforced by pyramiding=0)
// ══════════════════════════════════════════════════════════════════════════════
if longSetup and longRR >= rrMin and strategy.opentrades < 3
    strategy.entry("ICT Long", strategy.long, comment="▲ ICT Long")
    strategy.exit("L-TP1", "ICT Long", qty_percent=tp1Pct, limit=longTP1,  stop=longSL)
    strategy.exit("L-TP2", "ICT Long", qty_percent=tp2Pct, limit=longTP2,  stop=longSL)
    strategy.exit("L-TP3", "ICT Long", qty_percent=100,    stop=longSL,    trail_points=trailPts)

if shortSetup and shortRR >= rrMin and strategy.opentrades < 3
    strategy.entry("ICT Short", strategy.short, comment="▼ ICT Short")
    strategy.exit("S-TP1", "ICT Short", qty_percent=tp1Pct, limit=shortTP1, stop=shortSL)
    strategy.exit("S-TP2", "ICT Short", qty_percent=tp2Pct, limit=shortTP2, stop=shortSL)
    strategy.exit("S-TP3", "ICT Short", qty_percent=100,    stop=shortSL,   trail_points=trailPts)

// ══════════════════════════════════════════════════════════════════════════════
// VISUALS
// ══════════════════════════════════════════════════════════════════════════════

// --- Swing pivots
plotshape(swingHigh, "Swing High", shape.triangledown, location.abovebar, color.red,   size=size.tiny)
plotshape(swingLow,  "Swing Low",  shape.triangleup,   location.belowbar, color.green, size=size.tiny)

// --- Entry signals
plotshape(longSetup  and longRR  >= rrMin ? low  : na, "Long Signal",
          shape.arrowup,   location.belowbar, color.lime, size=size.normal)
plotshape(shortSetup and shortRR >= rrMin ? high : na, "Short Signal",
          shape.arrowdown, location.abovebar, color.red,  size=size.normal)

// --- Liquidity sweep labels
if showSweeps
    if sweepLow
        label.new(bar_index, low, "Sweep ↑", color=color.teal,
                  textcolor=color.white, style=label.style_label_up,   size=size.tiny)
    if sweepHigh
        label.new(bar_index, high, "Sweep ↓", color=color.maroon,
                  textcolor=color.white, style=label.style_label_down, size=size.tiny)

// --- Order block boxes
if showOB
    if bosUp and not na(bullOBH)
        box.new(bullOBBar, bullOBH, bar_index + 30, bullOBL,
                border_color=color.green, bgcolor=color.new(color.green, 85), text="Bull OB")
    if bosDown and not na(bearOBH)
        box.new(bearOBBar, bearOBH, bar_index + 30, bearOBL,
                border_color=color.red, bgcolor=color.new(color.red, 85), text="Bear OB")

// --- FVG shading
bgcolor(showFVG and bullFVG ? color.new(color.aqua,   92) : na, title="Bull FVG")
bgcolor(showFVG and bearFVG ? color.new(color.orange, 92) : na, title="Bear FVG")

// --- Kill zone shading
bgcolor(inKillZone ? color.new(color.yellow, 96) : na, title="Kill Zone")

// ══════════════════════════════════════════════════════════════════════════════
// INFO TABLE (top-right)
// ══════════════════════════════════════════════════════════════════════════════
var table t = table.new(position.top_right, 2, 7,
                        frame_color=color.gray, frame_width=1, border_width=1)

colorGreen = color.new(color.green, 20)
colorRed   = color.new(color.red,   20)
colorGray  = color.new(color.gray,  20)
colorTeal  = color.new(color.teal,  20)

if showTable and barstate.islast
    table.cell(t, 0, 0, "TechnobizTrader", text_color=color.white, bgcolor=color.navy, text_halign=text.align_center)
    table.cell(t, 1, 0, "Gold ICT v6",     text_color=color.white, bgcolor=color.navy, text_halign=text.align_center)

    table.cell(t, 0, 1, "HTF Bias",    text_color=color.white, bgcolor=colorGray)
    table.cell(t, 1, 1, htfBull ? "BULLISH ▲" : htfBear ? "BEARISH ▼" : "NEUTRAL",
               text_color=color.white,
               bgcolor=htfBull ? colorGreen : htfBear ? colorRed : colorGray)

    table.cell(t, 0, 2, "Structure",   text_color=color.white, bgcolor=colorGray)
    table.cell(t, 1, 2, bullStruct ? "HH/HL ▲" : bearStruct ? "LH/LL ▼" : "RANGING",
               text_color=color.white,
               bgcolor=bullStruct ? colorGreen : bearStruct ? colorRed : color.new(color.orange, 20))

    table.cell(t, 0, 3, "Kill Zone",   text_color=color.white, bgcolor=colorGray)
    table.cell(t, 1, 3, inKillZone ? "ACTIVE ✓" : "INACTIVE",
               text_color=color.white,
               bgcolor=inKillZone ? colorTeal : colorGray)

    table.cell(t, 0, 4, "Sweep Low",   text_color=color.white, bgcolor=colorGray)
    table.cell(t, 1, 4, sweepLow  ? "YES ✓" : "NO",
               text_color=color.white,
               bgcolor=sweepLow  ? colorGreen : colorGray)

    table.cell(t, 0, 5, "Sweep High",  text_color=color.white, bgcolor=colorGray)
    table.cell(t, 1, 5, sweepHigh ? "YES ✓" : "NO",
               text_color=color.white,
               bgcolor=sweepHigh ? colorRed : colorGray)

    table.cell(t, 0, 6, "Open Trades", text_color=color.white, bgcolor=colorGray)
    table.cell(t, 1, 6, str.tostring(strategy.opentrades) + " / 3",
               text_color=color.white,
               bgcolor=strategy.opentrades >= 3 ? colorRed : colorGreen)
