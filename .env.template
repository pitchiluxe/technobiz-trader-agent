# TechnobizTrader Environment Variables Template
#
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Replace all placeholder values with your actual credentials
# 3. Items marked [REQUIRED] must be filled in for trading to work
# 4. Items marked [OPTIONAL] are nice-to-have
# 5. For PRODUCTION, set ENVIRONMENT=production and use PostgreSQL
#
# WARNING: Never commit your .env file to version control!
#          It contains sensitive credentials. Add .env to .gitignore

################################################################################
# APPLICATION SETTINGS
################################################################################

# Deployment environment: "development" or "production"
# In production mode, additional validation is enforced
ENVIRONMENT=development

# Debug mode (disable in production)
# Only shows DEBUG logs when ENVIRONMENT != production
DEBUG=False

# Logging configuration
LOG_LEVEL=INFO
LOG_FILE=logs/technobiz_trader.log

################################################################################
# DATA PROVIDER SELECTION
################################################################################

# Choose your market data provider:
# - "mt5"         : MetaTrader 5 only (execution + analysis)
# - "tradingview" : TradingView only (analysis only, no execution)
# - "hybrid"      : Both MT5 + TradingView (recommended)
# 
# See DATA_PROVIDERS.md for detailed comparison
DATA_PROVIDER=mt5

# TradingView configuration (if using tradingview or hybrid)
# API type: "free" (1-minute delayed) or "premium" (real-time + webhooks)
TRADINGVIEW_API_TYPE=free

# TradingView exchange (FOREX, Binance, NYSE, NASDAQ, etc.)
TRADINGVIEW_EXCHANGE=FOREX

################################################################################
# REQUIRED: METATRADER 5 CREDENTIALS (for live market data)
################################################################################

# Your MetaTrader 5 account number (numeric)
# Example: 123456789
# Required if DATA_PROVIDER is "mt5" or "hybrid"
MT5_ACCOUNT=YOUR_MT5_ACCOUNT_NUMBER

# Your MetaTrader 5 password
# Required if DATA_PROVIDER is "mt5" or "hybrid"
MT5_PASSWORD=YOUR_MT5_PASSWORD

# MetaTrader 5 broker server
# Examples: "MetaQuotes-Demo", "ICMarkets-Demo", "Exness-MT5-Demo"
# Required if DATA_PROVIDER is "mt5" or "hybrid"
MT5_SERVER=YOUR_MT5_SERVER

################################################################################
# REQUIRED: TRADING ACCOUNT
################################################################################

# Your trading account balance in USD
# This is used for position sizing and risk calculation
# IMPORTANT: Must be > 0 and reflect your actual account size
ACCOUNT_BALANCE=10000

# Maximum concurrent open trades at any time
MAX_CONCURRENT_TRADES=3

# Maximum risk per trade as decimal (0.02 = 2% of account balance)
MAX_RISK_PER_TRADE=0.02

# Minimum confidence score (0-100) required to execute a trade
MIN_CONFIDENCE_THRESHOLD=75

# Comma-separated list of trading pairs (symbols)
TRADING_PAIRS=EURUSD,GBPUSD,USDJPY

################################################################################
# REQUIRED: DATABASE CONFIGURATION
################################################################################

# Database connection string
# 
# FOR PRODUCTION: Use PostgreSQL
#   postgresql://username:password@hostname:5432/database_name
#   Example: postgresql://trader:secure_pass@db.example.com:5432/technobiz_trader
#
# FOR DEVELOPMENT: SQLite is acceptable (default)
#   sqlite:///./technobiz_trader.db
#
# In production mode (ENVIRONMENT=production), SQLite is NOT allowed
DATABASE_URL=sqlite:///./technobiz_trader.db

################################################################################
# REQUIRED: AZURE AI FOUNDRY (for agent model inference)
################################################################################

# Azure AI Foundry project endpoint URL
# Format: https://[project-name].azure.ai.com
FOUNDRY_PROJECT_ENDPOINT=https://your-foundry-endpoint.azure.ai.com

# Model deployment name in Azure AI Foundry
# Example: "gpt-4-deployment" or "claude-3-deployment"
FOUNDRY_MODEL_DEPLOYMENT_NAME=your-model-deployment-name

# Azure AI Foundry API key for authentication
FOUNDRY_API_KEY=your-foundry-api-key

################################################################################
# REQUIRED: DASHBOARD API KEY (protects the FastAPI backend from external access)
################################################################################

# Secret key for the trading dashboard API.
# The trading_command_center.html sends this in the x-api-key header on every
# request.  If left empty the backend runs in dev mode (no auth enforced).
# Generate a strong random key for production, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_API_KEY=

################################################################################
# OPTIONAL: RISK SETTINGS PATH
################################################################################

# Custom path for the user risk settings JSON file.
# Defaults to risk_settings.json in the project root if not set.
# Useful when the project root is read-only (Docker volume mounts, etc.)
#   Example: /data/config/risk_settings.json
RISK_SETTINGS_PATH=

################################################################################
# OPTIONAL: ALPACA MARKETS (alternative data source - not required if using MT5)
################################################################################

# Alpaca API key (only needed if using Alpaca instead of MT5)
ALPACA_API_KEY=

# Alpaca Secret key
ALPACA_SECRET_KEY=

################################################################################
# OPTIONAL: EMAIL NOTIFICATIONS
################################################################################

# Enable email alerts for trade execution and signals
ENABLE_EMAIL_NOTIFICATIONS=False

# Email address to receive notifications
EMAIL_RECIPIENT=your-email@example.com

################################################################################
# OPTIONAL: TELEGRAM NOTIFICATIONS
################################################################################

# Enable Telegram bot for real-time alerts
ENABLE_TELEGRAM_NOTIFICATIONS=False

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram chat ID where alerts should be sent
TELEGRAM_CHAT_ID=

################################################################################
# PRODUCTION CHECKLIST
################################################################################

# Before running in PRODUCTION, ensure:
#
# [ ] ENVIRONMENT=production
# [ ] DEBUG=False
# [ ] DATABASE_URL uses PostgreSQL (not SQLite)
# [ ] MT5_ACCOUNT, MT5_PASSWORD, MT5_SERVER are set correctly
# [ ] ACCOUNT_BALANCE reflects your actual trading account
# [ ] FOUNDRY_PROJECT_ENDPOINT and FOUNDRY_API_KEY are set
# [ ] DASHBOARD_API_KEY is set to a strong random value (32+ hex chars)
# [ ] All database credentials are correct
# [ ] MT5 terminal is running on the deployment machine
# [ ] Database is backed up and accessible
# [ ] Network connectivity is stable
# [ ] Monitoring/alerts are configured
# [ ] Risk management parameters are reviewed
# [ ] This file (.env) is in .gitignore and never committed
#
# Then: export ENVIRONMENT=production && python main.py

